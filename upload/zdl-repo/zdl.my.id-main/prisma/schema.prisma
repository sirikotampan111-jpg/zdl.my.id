generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  image        String?
  phone        String?
  businessName String?
  password     String?
  role         String   @default("customer")
  provider     String   @default("google")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders    Order[]
  projects  Project[]
}

model Order {
  id              String   @id @default(cuid())
  orderId         String   @unique
  userId          String
  packageName     String
  packageCategory String   @default("html")
  packagePrice    Int
  ppnAmount       Int      @default(0)
  transactionFee  Int      @default(0)
  payAmount       Int
  dpMinimal       Int      @default(0)
  isDP            Boolean  @default(false)
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  businessName    String?
  notes           String?
  status          String   @default("pending")
  paymentMethod   String?
  paymentType     String?
  snapToken       String?
  snapRedirectUrl String?
  expiredAt       DateTime?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  project      Project?

  @@index([userId])
  @@index([status])
}

model Transaction {
  id               String   @id @default(cuid())
  orderId          String
  transactionId    String?
  transactionTime  DateTime?
  transactionStatus String?
  paymentType      String?
  grossAmount      Int?
  currency         String   @default("IDR")
  fraudStatus      String?
  rawResponse      String?
  createdAt        DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([transactionId])
}

model Project {
  id             String   @id @default(cuid())
  orderId        String   @unique
  userId         String
  projectName    String
  packageCategory String  @default("html")
  status         String   @default("planning")
  progress       Int      @default(0)
  notes          String?
  liveUrl        String?
  startedAt      DateTime?
  estimatedDone  DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order      Order       @relation(fields: [orderId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  milestones Milestone[]

  @@index([userId])
  @@index([status])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  status      String    @default("pending")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}
